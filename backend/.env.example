# Backend Environment Variables
# Copy to .env and configure values

# Server
PORT=5000
NODE_ENV=development

# Database (Railway provides MONGODB_URI automatically with MongoDB addon)
MONGODB_URI=mongodb://localhost:27017/taskforge

# JWT Authentication (REQUIRED - generate a secure random string)
JWT_SECRET=your-secret-key-min-64-chars-change-this-in-production

# Frontend URL for CORS (update with your deployed frontend URL)
FRONTEND_URL=http://localhost:5173

# Node Environment (optional)
NODE_OPTIONS=--max-old-space-size=4096
